<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GOUDA GAZE — Users</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
</head>
<body>
    <div id="app-container">
        <div id="top-bar">
            <h1>Gouda Gaze</h1>
        </div>
        <nav class="page-nav">
            <a href="/" class="nav-link">&#9654; Live</a>
            <a href="/gallery" class="nav-link">&#9783; Gallery</a>
            <a href="/admin/users" class="nav-link nav-link-active">
                &#9881; Users
                {% if pending_count > 0 %}
                <span class="nav-badge">{{ pending_count }}</span>
                {% endif %}
            </a>
            <span class="nav-user">{{ current_user.name }}</span>
            <a href="/logout" class="nav-link nav-link-logout">&#8594; Logout</a>
        </nav>

        <!-- Shared column widths — all three tables reference this -->
        <!-- Name 18% | Email 28% | Status 14% | Date 18% | Actions 22% -->

        <!-- ── Pending requests ─────────────────────────── -->
        <div class="admin-section">
            <div class="admin-section-title">
                Pending Requests
                {% if pending %}
                <span class="admin-badge admin-badge-alert">{{ pending | length }}</span>
                {% endif %}
            </div>

            {% if pending %}
            <table class="admin-table">
                <colgroup>
                    <col class="col-name">
                    <col class="col-email">
                    <col class="col-status">
                    <col class="col-date">
                    <col class="col-actions">
                </colgroup>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Requested Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in pending %}
                    <tr>
                        <td>{{ user.name }}</td>
                        <td style="opacity: 0.7;">{{ user.email }}</td>
                        <td><span class="status-badge status-pending">Pending</span></td>
                        <td style="opacity: 0.5; font-size: 0.75rem;">{{ user.created_at.strftime('%Y-%m-%d') }}</td>
                        <td>
                            <div class="admin-actions">
                                <form method="POST" action="/admin/users/{{ user.id }}/approve">
                                    <button class="btn-sm btn-sm-approve" type="submit">Approve</button>
                                </form>
                                <form method="POST" action="/admin/users/{{ user.id }}/deny">
                                    <button class="btn-sm btn-sm-deny" type="submit">Deny</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <p class="admin-empty">No pending requests.</p>
            {% endif %}
        </div>

        <!-- ── Active users ─────────────────────────────── -->
        <div class="admin-section">
            <div class="admin-section-title">
                Active Users
                <span class="admin-badge">{{ approved | length }}</span>
            </div>

            {% if approved %}
            <table class="admin-table">
                <colgroup>
                    <col class="col-name">
                    <col class="col-email">
                    <col class="col-status">
                    <col class="col-date">
                    <col class="col-actions">
                </colgroup>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Approval Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in approved %}
                    <tr>
                        <td>
                            {{ user.name }}
                            {% if user.id == current_user.id %}
                            <span class="admin-you-badge">(you)</span>
                            {% endif %}
                        </td>
                        <td style="opacity: 0.7;">{{ user.email }}</td>
                        <td>
                            <span class="role-badge {{ 'role-admin' if user.is_admin else 'role-viewer' }}">
                                {{ user.role }}
                            </span>
                        </td>
                        <td style="opacity: 0.5; font-size: 0.75rem;">{{ user.created_at.strftime('%Y-%m-%d') }}</td>
                        <td>
                            {% if user.id != current_user.id %}
                            <div class="admin-actions">
                                <form method="POST" action="/admin/users/{{ user.id }}/role" style="display: flex; align-items: center; gap: 4px;">
                                    <select class="role-select" name="role">
                                        <option value="viewer" {{ 'selected' if user.role == 'viewer' else '' }}>viewer</option>
                                        <option value="admin"  {{ 'selected' if user.role == 'admin'  else '' }}>admin</option>
                                    </select>
                                    <button class="btn-sm" type="submit">Apply</button>
                                </form>
                                <form method="POST" action="/admin/users/{{ user.id }}/revoke">
                                    <button class="btn-sm btn-sm-revoke" type="submit">Revoke</button>
                                </form>
                            </div>
                            {% else %}
                            <span style="opacity: 0.25; font-size: 0.75rem;">—</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
            {% else %}
            <p class="admin-empty">No active users.</p>
            {% endif %}
        </div>

        <!-- ── Denied ────────────────────────────────────── -->
        {% if denied %}
        <div class="admin-section">
            <div class="admin-section-title">
                Denied
                <span class="admin-badge" style="opacity: 0.5;">{{ denied | length }}</span>
            </div>
            <table class="admin-table">
                <colgroup>
                    <col class="col-name">
                    <col class="col-email">
                    <col class="col-status">
                    <col class="col-date">
                    <col class="col-actions">
                </colgroup>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Denied Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in denied %}
                    <tr style="opacity: 0.55;">
                        <td>{{ user.name }}</td>
                        <td>{{ user.email }}</td>
                        <td><span class="status-badge status-denied">Denied</span></td>
                        <td style="font-size: 0.75rem;">{{ user.created_at.strftime('%Y-%m-%d') }}</td>
                        <td>
                            <form method="POST" action="/admin/users/{{ user.id }}/approve">
                                <button class="btn-sm btn-sm-approve" type="submit">Re-approve</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% endif %}

    </div>
</body>
</html>